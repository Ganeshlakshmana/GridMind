# GridMind — environment template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# Required: Anthropic API key for Claude agent + intent classifier
ANTHROPIC_API_KEY=sk-ant-...

# Optional: LangSmith tracing
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=gridmind

# Windows: force UTF-8 stdout/stderr (prevents UnicodeEncodeError)
PYTHONUTF8=1

# MCP server
MCP_HOST=0.0.0.0
MCP_PORT=8001

# FastAPI backend
API_HOST=0.0.0.0
API_PORT=8000
